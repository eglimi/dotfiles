{
    "layer": "top",
    "position": "top",
    "height": 34,
    "spacing": 2,
    "margin-top": 6,
    "margin-left": 8,
    "margin-right": 8,
    "modules-left": [
        "custom/launcher",
        "custom/workspaces",
        "group/sysmon",
        "wlr/taskbar"
    ],
    "modules-center": [
        "clock"
    ],
    "modules-right": [
        "tray",
        "group/controls",
        "custom/swaync",
        "custom/power"
    ],
    "group/sysmon": {
        "orientation": "horizontal",
        "modules": [
            "cpu",
            "temperature",
            "memory"
        ]
    },
    "group/controls": {
        "orientation": "horizontal",
        "modules": [
            "backlight",
            "pulseaudio",
            "pulseaudio#mic",
            "network",
            "bluetooth",
            "custom/ppd",
            "battery"
        ]
    },
    "custom/ppd": {
        "exec": "~/.config/waybar/ppd.sh",
        "return-type": "json",
        "interval": 5,
        "signal": 8,
        "on-click": "p=$(powerprofilesctl get); case $p in power-saver) powerprofilesctl set balanced;; balanced) powerprofilesctl set performance;; *) powerprofilesctl set power-saver;; esac; pkill -RTMIN+8 waybar"
    },
    "wlr/taskbar": {
        "format": "{icon}",
        "icon-size": 18,
        "tooltip-format": "{title}",
        "on-click": "activate",
        "on-click-middle": "close",
        "ignore-list": []
    },
    "custom/launcher": {
        "format": "",
        "tooltip": false,
        "on-click": "fuzzel"
    },
    "custom/workspaces": {
        "exec": "~/.config/waybar/niri-workspaces.sh",
        "return-type": "json",
        "tooltip": false
    },
    "clock": {
        "format": "  {:%a %d %b  %H:%M}",
        "tooltip": false,
        "on-click": "gsimplecal"
    },
    "custom/swaync": {
        "tooltip": false,
        "format": "{icon} <span foreground='#fabd2f' rise='2pt' size='8pt'>{}</span>",
        "format-icons": {
            "notification": "<span foreground='#fabd2f'>󰂚</span>",
            "none": "󰂜",
            "dnd-notification": "<span foreground='#fabd2f'>󰂛</span>",
            "dnd-none": "󰂛",
            "inhibited-notification": "<span foreground='#fabd2f'>󰂚</span>",
            "inhibited-none": "󰂜",
            "dnd-inhibited-notification": "<span foreground='#fabd2f'>󰂛</span>",
            "dnd-inhibited-none": "󰂛"
        },
        "return-type": "json",
        "exec-if": "which swaync-client",
        "exec": "swaync-client -swb",
        "on-click": "swaync-client -t -sw",
        "on-click-right": "swaync-client -d -sw",
        "escape": true
    },
    "tray": {
        "icon-size": 16,
        "spacing": 8
    },
    "backlight": {
        "format": "{icon} <span rise='1pt' size='9pt'>{percent}%</span>",
        "format-icons": [
            "",
            "",
            ""
        ],
        "on-scroll-up": "brightnessctl set 5%+",
        "on-scroll-down": "brightnessctl set 5%-",
        "on-click-right": "gnome-control-center display"
    },
    "pulseaudio": {
        "format": "{icon} <span rise='1pt' size='9pt'>{volume}%</span>",
        "format-muted": " muted",
        "format-icons": {
            "default": [
                "",
                "",
                ""
            ]
        },
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle; wpctl get-volume @DEFAULT_AUDIO_SINK@ | grep -q MUTED && wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 1 || wpctl set-mute @DEFAULT_AUDIO_SOURCE@ 0",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SINK@ 2%-"
    },
    "pulseaudio#mic": {
        "format": "{format_source}",
        "format-source": " <span rise='1pt' size='9pt'>{volume}%</span>",
        "format-source-muted": " muted",
        "tooltip-format": "Mic: {source_volume}%",
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SOURCE@ toggle",
        "on-click-right": "pavucontrol",
        "on-scroll-up": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 2%+",
        "on-scroll-down": "wpctl set-volume @DEFAULT_AUDIO_SOURCE@ 2%-"
    },
    "network": {
        "format-wifi": " <span rise='1pt' size='9pt'>{signalStrength}%</span>",
        "format-ethernet": " <span rise='1pt' size='9pt'>{ipaddr}</span>",
        "format-disconnected": " offline",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)",
        "on-click": "nm-connection-editor",
        "on-click-right": "nm-connection-editor"
    },
    "bluetooth": {
        "format": "󰂯 <span rise='1pt' size='9pt'>{num_connections}</span>",
        "format-disabled": "󰂲",
        "format-off": "󰂲",
        "format-connected": "󰂱 <span rise='1pt' size='9pt'>{num_connections}</span>",
        "tooltip-format": "{controller_alias}\n{status}",
        "tooltip-format-connected": "{controller_alias}\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}",
        "on-click": "blueman-manager",
        "on-click-right": "blueman-manager"
    },
    "temperature": {
        "thermal-zone": 19,
        "critical-threshold": 85,
        "format": " <span rise='1pt' size='9pt'>{temperatureC}°C</span>",
        "format-critical": " <span rise='1pt' size='9pt'>{temperatureC}°C</span>",
        "on-click-right": "gnome-system-monitor"
    },
    "cpu": {
        "format": " <span rise='1pt' size='9pt'>{usage}%</span>",
        "interval": 2,
        "on-click-right": "gnome-system-monitor"
    },
    "memory": {
        "format": " <span rise='1pt' size='9pt'>{percentage}%</span>",
        "interval": 5,
        "on-click-right": "gnome-system-monitor"
    },
    "battery": {
        "states": {
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} <span rise='1pt' size='9pt'>{capacity}%</span>",
        "format-charging": " <span rise='1pt' size='9pt'>{capacity}%</span>",
        "format-plugged": " <span rise='1pt' size='9pt'>{capacity}%</span>",
        "format-icons": [
            "",
            "",
            "",
            "",
            ""
        ],
        "on-click-right": "gnome-control-center power"
    },
    "custom/power": {
        "format": "",
        "tooltip": false,
        "on-click": "~/.config/waybar/powermenu.sh"
    }
}
